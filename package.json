{
  "name": "jira-desktop",
  "productName": "Jira Desktop",
  "version": "1.0.0",
  "description": "A minimal Electron desktop client for Jira.",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test:smoke": "node tests/smoke.js",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release-win": "electron-builder --config.asar=true --config.compression=maximum --win --publish never",
    "release-mac": "electron-builder --config.asar=true --config.compression=maximum --mac --publish never"
  },
  "keywords": [
    "electron",
    "jira",
    "desktop"
  ],
  "author": "Prakhar Prakash Bhardwaj",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "playwright": "^1.59.1"
  },
  "build": {
    "asar": true,
    "compression": "maximum",
    "mac": {
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.png"
    }
  }
}
